<mujoco>
    <option gravity="0 0 0" />
    <worldbody>
        <light diffuse=".5 .5 .5" pos="0 0 3" dir="0 0 -1"/>
        <geom type="plane" size="10 10 0.1" rgba=".9 .9 .9 1" friction="0 0 0"/>
        <geom type="plane" size=".01 .01 0.1" pos=".25 .25 0" rgba=".9 0 0 1" friction="0 0 0"/>
        <body pos="0 0 .1">
            <joint name="x" type="slide" axis="1 0 0" damping="1"/>
            <joint name="y" type="slide" axis="0 1 0" damping="1"/>

            <geom type="box" size=".1 .1 .1" rgba=".9 0 0 1" friction="0 0 0"/>
        </body>
        
    </worldbody>
    <actuator>
        <motor joint="x"/>
        <motor joint="y"/>
    </actuator>
</mujoco>