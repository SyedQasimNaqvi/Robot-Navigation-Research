<mujoco>
    <option gravity="0 0 0"/>

    <worldbody>
        <geom type="plane" size="10 10 0.1"/>

        <body>
            <joint name="slide_x" type="slide" axis="1 0 0"/>
            <joint name="slide_y" type="slide" axis="0 1 0"/>

            <geom type="box" size="0.1 0.1 0.1"/>
        </body>
    </worldbody>

    <actuator>
        <motor joint="slide_x"/>
        <motor joint="slide_y"/>
    </actuator>
</mujoco>